ARG OWNER="zanbaldwin"
ARG FEDORA_VERSION="44"
ARG VARIANT="silverblue"
# Fedora 39 is the first to officially ship as an OCI image; before then the
# unofficial images could be found at "quay.io/fedora-ostree-desktops/${VARIANT}".
ARG IMAGE="quay.io/fedora/fedora-${VARIANT}"
ARG LINUX_VERSION="7.0.12"


FROM "fedora:${FEDORA_VERSION}" AS secureboot
RUN dnf install --assumeyes openssl \
 && mkdir -p '/opt/secureboot' \
 && openssl req -new -x509 -newkey 'rsa:4096' -nodes -days 36500 \
        -outform DER -out '/opt/secureboot/cert.der' \
        -keyout '/opt/secureboot/key.pem' \
        -subj '/CN=${NAMESPACE}/' \
 && openssl pkcs12 -export -out '/opt/secureboot/key.p12' -inkey '/opt/secureboot/key.pem' -in '/opt/secureboot/cert.der'


# ================= #
# Custom kernel RPM #
# ================= #
FROM "fedora:${FEDORA_VERSION}" AS kernel
ARG FEDORA_VERSION
ARG LINUX_VERSION
ARG OWNER
# Install Rust
RUN dnf install --assumeyes cmake curl gcc g++ git \
 && curl --proto '=https' --tlsv1.2 -sSf 'https://sh.rustup.rs' >'/tmp/rustup.sh' \
 && sh '/tmp/rustup.sh' -qy
# Sources
RUN git clone --depth=1 --branch="f${FEDORA_VERSION}" 'https://src.fedoraproject.org/rpms/kernel.git' '/tmp/fedpkg' \
 && dnf install --assumeyes 'dnf-command(builddep)' clang-devel fedpkg gcc-c++ git libXi-devel lld make ncurses-devel perl qt3-devel rsync \
 && dnf builddep --assumeyes '/tmp/fedpkg/kernel.spec'
ARG LINUX_GIT_REPO="git://git.kernel.org/pub/scm/linux/kernel/git/stable/linux-stable.git"
RUN if [ -n "${LINUX_VERSION}" ]; then \
        LINUX_TARGET_VERSION="v${LINUX_VERSION}"; \
    else \
        LINUX_TARGET_VERSION="$(git -c 'versionsort.suffix=-' ls-remote --tags --sort='v:refname' "${LINUX_GIT_REPO}" \
            | grep -v '\^' | grep -P -e '\d+\.\d+' | grep -P -v 'alpha|ALPHA|beta|BETA|rc|RC|-' \
            | cut -d'/' -f3 | sort --version-sort | tail -n1)"; \
    fi \
 && echo "Targeting stable version of Linux Kernel: ${LINUX_TARGET_VERSION}" \
 && git clone --depth=1 --branch="${LINUX_TARGET_VERSION}" "${LINUX_GIT_REPO}" '/tmp/linux'
# Rust Build Tools
RUN source "${HOME}/.cargo/env" \
 && export LINUX_RUST_VERSION="$('/tmp/linux/scripts/min-tool-version.sh' rustc)" \
 && rustup toolchain add "${LINUX_RUST_VERSION}" \
 && rustup component add --toolchain="${LINUX_RUST_VERSION}" 'rust-src' \
 && rustup override set --path='/tmp/linux' "${LINUX_RUST_VERSION}" \
 && cargo install --locked --version "$('/tmp/linux/scripts/min-tool-version.sh' bindgen)" 'bindgen-cli'
# Custom Kernel Configuration
COPY 'custom_kernel.config' '/tmp/custom_kernel.config'
COPY 'patches' '/tmp/patches'
# Configure Kernel
RUN source "${HOME}/.cargo/env" \
 && cd '/tmp/linux' \
 && sed -i -E "s/^.*CONFIG_RUSTC_VERSION_TEXT.*$/CONFIG_RUSTC_VERSION_TEXT=\"$(rustc --version)\"/g" '/tmp/custom_kernel.config' \
 && sed -i -E "s/^.*CONFIG_BINDGEN_VERSION_TEXT.*$/CONFIG_BINDGEN_VERSION_TEXT=\"$(bindgen --version)\"/g" '/tmp/custom_kernel.config' \
 && KCONFIG_CONFIG='/tmp/kernel-custom-build.config' bash '/tmp/linux/scripts/kconfig/merge_config.sh' \
        "/tmp/fedpkg/kernel-$(uname -m)-fedora.config" \
        '/tmp/custom_kernel.config' \
 && sed -i "s/^EXTRAVERSION.*/EXTRAVERSION = -${OWNER}/g" '/tmp/linux/Makefile' \
 && git config user.name 'Zan Baldwin (Container Build)' \
 && git config user.email 'hello+build@zanbaldwin.com' \
 && find '/tmp/patches' -type 'f' -name '*.patch' -exec git -C '/tmp/linux' am '{}' +
# Build Kernel
RUN source "${HOME}/.cargo/env" \
 && git -C '/tmp/linux' clean -d -f -x \
 && mv '/tmp/kernel-custom-build.config' '/tmp/linux/.config' \
 && echo "Building Linux kernel version '$(make -C "/tmp/linux" --no-print-directory kernelversion)'." \
 && sed -i '/^Provides: kernel-%{KERNELRELEASE}/a Provides: kernel-uname-r = %{KERNELRELEASE}' '/tmp/linux/scripts/package/kernel.spec' \
 && sed -i '/^%package devel/a Provides: kernel-devel-uname-r = %{KERNELRELEASE}' '/tmp/linux/scripts/package/kernel.spec' \
 && make -C '/tmp/linux' -j "$(nproc --all)" rpm-pkg \
 && mkdir -p '/opt/kernel' \
 && find '/tmp/linux/rpmbuild/RPMS' -type 'f' -name '*.rpm' -exec cp --target-directory='/opt/kernel' '{}' +


# ========================================================= #
# Build the NVIDIA kernel module against our custom kernel. #
# ========================================================= #
FROM "fedora:${FEDORA_VERSION}" AS custom-nvidia
ARG FEDORA_VERSION
ARG LINUX_VERSION
ARG OWNER
COPY --from='kernel' '/opt/kernel' '/opt/kernel'
RUN dnf install --assumeyes \
        "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm" \
        "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm" \
 && dnf install --assumeyes "/opt/kernel/kernel-devel-"*.rpm \
 && KVER="$(basename /usr/lib/modules/*-"${OWNER}"*)" \
 && echo '%_with_kmod_nvidia_open 1' >'/etc/rpm/macros.nvidia-kmod' \
 && dnf install --assumeyes akmod-nvidia \
 && { akmods --force --kernels "${KVER}" --kmod 'nvidia'; \
      echo '=== akmods failed.log (if any) ==='; \
      cat /var/cache/akmods/nvidia/*.failed.log 2>/dev/null || true; } \
 && mkdir -p '/opt/nvidia' \
 && cp /var/cache/akmods/nvidia/kmod-nvidia-*.rpm '/opt/nvidia/' \
 && dnf download --destdir='/opt/nvidia' \
        xorg-x11-drv-nvidia xorg-x11-drv-nvidia-libs \
        xorg-x11-drv-nvidia-cuda xorg-x11-drv-nvidia-cuda-libs \
        xorg-x11-drv-nvidia-power nvidia-kmod-common \
        nvidia-modprobe nvidia-settings nvidia-persistenced


# ========================================================== #
# Build the NVIDIA kernel module against the STOCK kernel.    #
# ========================================================== #
# Read the exact kernel version shipped in the base OS image so the kmod is built
# against THAT kernel, not whatever is newest in the Fedora repos. Both this stage
# and the `stock` stage derive from the same `${IMAGE}:${FEDORA_VERSION}`, so the
# version is guaranteed to match.
FROM "${IMAGE}:${FEDORA_VERSION}" AS stock-kernel
RUN rpm --query --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' 'kernel-core' | tail -n1 >'/kver.txt'
FROM "fedora:${FEDORA_VERSION}" AS stock-nvidia
ARG FEDORA_VERSION
COPY --from='stock-kernel' '/kver.txt' '/kver.txt'
RUN echo "Installing nVidia drivers for kernel version: $(cat '/kver.txt')" \
 && dnf install --assumeyes \
        "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VERSION}.noarch.rpm" \
        "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VERSION}.noarch.rpm" \
 && KVER="$(cat /kver.txt)" \
 && dnf install --assumeyes "kernel-core-${KVER}" "kernel-devel-${KVER}" \
 && rpm --query "kernel-core-${KVER}" "kernel-devel-${KVER}" \
 && echo '%_with_kmod_nvidia_open 1' >'/etc/rpm/macros.nvidia-kmod' \
 && dnf install --assumeyes akmod-nvidia \
 && { akmods --force --kernels "${KVER}" --kmod 'nvidia'; \
      echo '=== akmods failed.log (if any) ==='; \
      cat /var/cache/akmods/nvidia/*.failed.log 2>/dev/null || true; } \
 && mkdir -p '/opt/nvidia' \
 && cp /var/cache/akmods/nvidia/kmod-nvidia-*.rpm '/opt/nvidia/' \
 && dnf download --arch='x86_64' --destdir='/opt/nvidia' \
        xorg-x11-drv-nvidia xorg-x11-drv-nvidia-libs \
        xorg-x11-drv-nvidia-cuda xorg-x11-drv-nvidia-cuda-libs \
        xorg-x11-drv-nvidia-power \
        nvidia-modprobe nvidia-settings nvidia-persistenced


# =============================== #
# Default Silverblue installation #
# =============================== #
FROM "${IMAGE}:${FEDORA_VERSION}" AS ostree
ARG FEDORA_VERSION
ARG LINUX_VERSION
LABEL org.opencontainers.image.version="${FEDORA_VERSION}+${LINUX_VERSION:-latest}" \
      org.opencontainers.image.authors="Zan Baldwin" \
      org.opencontainers.image.title="Silverblue" \
      containers.bootc="1"

# Kernel Virtual Machines
RUN rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" \
       bridge-utils edk2-ovmf guestfs-tools libvirt qemu-kvm virt-install virt-manager \
 && systemctl enable 'libvirtd' \
 && rm -rf /tmp/* /var/*

# Niri (+Kanshi/Kanata) + Noctalia Deps
RUN rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" \
        niri kanshi \
        cairo fontconfig freetype glib2 harfbuzz jemalloc libcurl libglvnd-egl \
        libglvnd-gles libqalculate librsvg2 libwayland-client libwayland-egl \
        libwebp libxkbcommon libxml2 pango pipewire-libs polkit-libs sdbus-cpp \
        ddcutil wireplumber brightnessctl wl-clipboard wlsunset cava \
 && systemctl --global enable 'kanshi.service' \
 && mkdir -p '/etc/udev/rules.d' \
 && echo 'KERNEL=="uinput", MODE="0660", GROUP="uinput", OPTIONS+="static_node=uinput"' >'/etc/udev/rules.d/99-uinput.rules' \
 && echo 'uinput' >'/etc/modules-load.d/uinput.conf' \
 && rm -rf /tmp/* /var/*

# Podman, DConf, and Flatpak services.
COPY './usr/' '/usr/'
RUN rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" \
       containernetworking-plugins aardvark-dns \
 && systemctl enable 'podman.service' \
 && systemctl enable 'podman.socket' \
 && systemctl enable 'podman-restart.service' \
 && systemctl enable 'flatpak-update.service' \
 && systemctl enable 'flatpak-update.timer' \
 && systemctl enable 'rpm-ostreed-automatic.timer' \
 && rm -rf /tmp/* /var/*

# Official Docker Engine
RUN curl -fsSL -o '/etc/yum.repos.d/docker-ce.repo' 'https://download.docker.com/linux/fedora/docker-ce.repo' \
 && rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin \
 && systemctl enable 'docker' \
 && rm -rf /tmp/* /var/*

# Ghostty Deps
RUN rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" gettext libadwaita gtk4-layer-shell \
 && rm -rf /tmp/* /var/*

# OpenH264 (non-free video codec from Cisco). The repo ships disabled in the base
# image; `dnf config-manager --set-enabled` simply flips `enabled=0` to `enabled=1`
# in the repo file, which we replicate with `sed` (DNF is unavailable on ostree).
# The base image ships the `noopenh264` stub (it provides `openh264` without the
# patent-encumbered codec); the real `openh264` obsoletes it, so we must drop the
# stub and install the codec in one transaction — `rpm-ostree install` alone won't
# replace a base-layer package.
RUN sed -i '0,/^enabled=0/s//enabled=1/' '/etc/yum.repos.d/fedora-cisco-openh264.repo' \
 && rpm-ostree override remove noopenh264 \
       --install openh264 \
       --install gstreamer1-plugin-openh264 \
       --install mozilla-openh264 \
 && rm -rf /tmp/* /var/*

# Misc Services
RUN rpm-ostree install --idempotent --allow-inactive --releasever="${FEDORA_VERSION}" distrobox ffmpeg-free fzf make ncdu nss-tools \
 && mkdir -p '/usr/lib/systemd/logind.conf.d/' \
 && { echo '[Login]'; echo 'HandleLidSwitchExternalPower=ignore'; } >'/usr/lib/systemd/logind.conf.d/10-lid.conf' \
 && rm -rf /tmp/* /var/*
# Recommended to avoid doing the following; commenting out for preservation.
#RUN if grep 'secure_path' '/etc/sudoers' >'/dev/null' 2>&1; then \
#       cat '/etc/sudoers' | grep -v 'secure_path' | tee '/etc/sudoers' >'/dev/null' 2>&1; \
#    fi

RUN ostree container commit


# ======================================================== #
# Apply our custom kernel + NVIDIA driver to the OS image. #
# ======================================================== #
FROM ostree AS custom
ARG LINUX_VERSION
ARG OWNER
COPY --from='kernel' '/opt/kernel' '/opt/kernel'
COPY --from='custom-nvidia' '/opt/nvidia' '/opt/nvidia'
# Force the nVidia + AMD iGPU drivers into every regenerated initramfs (hybrid
# GPU host), enable DRM KMS (required for Wayland/Niri), and blacklist nouveau.
RUN mkdir -p '/usr/lib/bootc/kargs.d' \
 && echo 'force_drivers+=" nvidia nvidia-modeset nvidia-drm nvidia-uvm amdgpu "' >'/usr/lib/dracut/dracut.conf.d/99-nvidia.conf' \
 && echo 'options nvidia_drm modeset=1 fbdev=1' >'/usr/lib/modprobe.d/nvidia-modeset.conf' \
 && printf '%s\n' 'kargs = ["rd.driver.blacklist=nouveau", "modprobe.blacklist=nouveau", "nvidia-drm.modeset=1"]' >'/usr/lib/bootc/kargs.d/00-nvidia.toml'
# Fedora ships a SPLIT kernel (kernel-core/-modules/-modules-core); our upstream
# `make rpm-pkg` build is a single MONOLITHIC `kernel` RPM, so a plain
# `override replace` can't map them. Remove the split base packages and install
# the monolithic kernel in the same transaction (one /usr/lib/modules tree), then
# install the matching nVidia kmod + userspace from the staged local RPMs and
# rebuild the initramfs for our kernel with the nVidia drivers baked in.
RUN KERNEL_RPM="$(ls /opt/kernel/kernel-[0-9]*.rpm)" \
 && rpm-ostree override remove kernel kernel-core kernel-modules kernel-modules-core kernel-modules-extra \
 && rpm-ostree install "${KERNEL_RPM}" /opt/nvidia/*.rpm \
 && KVER="$(basename /usr/lib/modules/*-"${OWNER}"*)" \
 && dracut --force --no-hostonly --reproducible --add ostree --kver "${KVER}" \
        "/usr/lib/modules/${KVER}/initramfs.img" \
 && rm -rf /opt/kernel /opt/nvidia /tmp/* /var/* \
 && ostree container commit


# ===================================================== #
# Stock Fedora kernel + NVIDIA driver applied to image. #
# ===================================================== #
FROM ostree AS stock
COPY --from='stock-nvidia' '/opt/nvidia' '/opt/nvidia'
# Force the nVidia + AMD iGPU drivers into every regenerated initramfs (hybrid
# GPU host), enable DRM KMS (required for Wayland/Niri), and blacklist nouveau.
RUN mkdir -p '/usr/lib/bootc/kargs.d' \
 && echo 'force_drivers+=" nvidia nvidia-modeset nvidia-drm nvidia-uvm amdgpu "' >'/usr/lib/dracut/dracut.conf.d/99-nvidia.conf' \
 && echo 'options nvidia_drm modeset=1 fbdev=1' >'/usr/lib/modprobe.d/nvidia-modeset.conf' \
 && printf '%s\n' 'kargs = ["rd.driver.blacklist=nouveau", "modprobe.blacklist=nouveau", "nvidia-drm.modeset=1"]' >'/usr/lib/bootc/kargs.d/00-nvidia.toml'
# The stock split kernel already ships in the base image and provides
# `kernel-uname-r`, so the staged nVidia kmod + userspace install cleanly (no
# `override remove` needed); just rebuild the initramfs for the stock kernel with
# the nVidia drivers baked in.
RUN KVER="$(rpm --query --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' 'kernel-core' | tail -n1)" \
 && rpm-ostree install /opt/nvidia/*.rpm \
 && dracut --force --no-hostonly --reproducible --add ostree --kver "${KVER}" \
        "/usr/lib/modules/${KVER}/initramfs.img" \
 && rm -rf /opt/nvidia /tmp/* /var/* \
 && ostree container commit
# Graphics passthru to containers.
RUN curl -fsSL -o '/etc/yum.repos.d/nvidia-container-toolkit.repo' \
       'https://nvidia.github.io/libnvidia-container/stable/rpm/nvidia-container-toolkit.repo' \
 && rpm-ostree install --idempotent --allow-inactive nvidia-container-toolkit \
 && rm -rf /tmp/* /var/*
RUN ostree container commit
