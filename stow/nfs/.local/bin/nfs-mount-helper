#!/usr/bin/env bash

# Privileged helper for `nfs-mount` -- invoked via pkexec, runs as root.
# Not meant to be called directly.
#
# Mode (argument 1):
#   mount    -> mount the NFS shares only
#   connect  -> start the Tailscale container, wait until healthy, then mount
#
# Mountpoints live under the *invoking* user's home directory, resolved from
# PKEXEC_UID and canonicalised (readlink -f). This handles both layouts without
# hard-coding a path: Fedora Workstation (/home/zan) and Silverblue, where
# /home is a symlink to /var/home (/var/home/zan).
#
# Exit codes (consumed by nfs-mount for notify-send):
#   0 success | 3 no Tailscale container | 4 container unhealthy | 5 mount error
set -euo pipefail

MODE="${1:-connect}"
CONTAINER='network-tailscale-1'
# Number of seconds to wait for the container to report healthy:
HEALTH_TIMEOUT='30'
SERVER='nas.lan.zanbaldwin.com'
MOUNT_OPTS='rw,vers=4.1,proto=tcp'

# Share name (mountpoint under the user's home) -> NFS export on the server.
declare -A SHARES=(
    ['Drive']='/mnt/tank4/drive'
    ['Music']='/mnt/tank4/music'
    ['Books']='/mnt/tank4/books'
)

# Resolve the invoking user's home from pkexec's UID, then canonicalise it so
# the mountpoint path contains no symlinks.
if [ -z "${PKEXEC_UID:-}" ]; then
    echo >&2 'nfs-mount-helper: PKEXEC_UID is unset; run via nfs-mount/pkexec'
    exit 5
fi
ENTRY="$(getent passwd "${PKEXEC_UID}" || true)"
GID="$(printf '%s' "${ENTRY}" | cut -d':' -f4)"
HOME="$(printf '%s' "${ENTRY}" | cut -d':' -f6)"
if [ -z "${HOME}" ] || [ ! -d "${HOME}" ]; then
    echo >&2 "nfs-mount-helper: cannot resolve home for UID #${PKEXEC_UID}"
    exit 5
fi
BASE="$(readlink -f -- "${HOME}")"

if [ "${MODE}" = 'connect' ]; then
    if ! podman container exists "${CONTAINER}"; then
        echo >&2 "nfs-mount-helper: container '${CONTAINER}' does not exist"
        exit 3
    fi
    podman start "${CONTAINER}" >'/dev/null' || {
        echo >&2 "nfs-mount-helper: failed to start '${CONTAINER}'"
        exit 4
    }

    status=''
    end=$((SECONDS + HEALTH_TIMEOUT))
    while [ "${SECONDS}" -lt "${end}" ]; do
        status="$(podman inspect --format '{{.State.Health.Status}}' "${CONTAINER}" 2>'/dev/null' || true)"
        if [ "${status}" = 'healthy' ]; then
            break
        fi
        # Force an immediate check rather than waiting on the 30s interval.
        podman healthcheck run "${CONTAINER}" >'/dev/null' 2>&1 || true
        sleep 2
    done
    if [ "${status}" != 'healthy' ]; then
        echo >&2 "nfs-mount-helper: '${CONTAINER}' not healthy after ${HEALTH_TIMEOUT}s (status: ${status:-unknown})"
        exit 4
    fi
fi

rc=0
for NAME in "${!SHARES[@]}"; do
    TARGET="${BASE}/${NAME}"
    EXPORT="${SHARES[${NAME}]}"

    if mountpoint -q -- "${TARGET}"; then
        continue
    fi
    if [ ! -d "${TARGET}" ]; then
        mkdir -p -- "${TARGET}"
        chown "${UID}:${GID}" -- "${TARGET}"
    fi
    if ! mount -t nfs -o "${MOUNT_OPTS}" "${SERVER}:${EXPORT}" "${TARGET}"; then
        echo >&2 "nfs-mount-helper: failed to mount ${SERVER}:${EXPORT} at ${TARGET}"
        rc=5
    fi
done

exit "${rc}"
