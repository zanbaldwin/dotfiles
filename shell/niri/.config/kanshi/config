output "eDP-1" {
    scale 1.0
    alias $INTERNAL
}
output "Samsung Electric Company LU28R55 H4ZT600868" {
    scale 1.0
    alias $LEFT4K
}
output "Samsung Electric Company LU28R55 BROKEN" {
    alias $RIGHT4K
}
output "Philips Consumer Electronics Company PHL 499P9 AU02345007801" {
    scale 1.0
    alias $ULTRAWIDE
}

profile laptop {
    output $INTERNAL enable position 0,0
}
profile docked-ultrawide {
    output $INTERNAL enable position 1600,1440
    output $ULTRAWIDE enable position 0,0
}
profile docked-4k-left {
    output $INTERNAL enable position 2880,2160
    output $LEFT4K enable position 0,0
}
profile docked-4k-right {
    output $INTERNAL enable position 0,2160
    output $RIGHT4K enable position 960,0
}
profile docked-4k-both {
    output $INTERNAL enable position 2880,2160
    output $LEFT4K enable position 0,0
    output $RIGHT4K enable position 3840,0
}

profile desktop-left {
    output $LEFT4K enable position 0,0
}
profile desktop-right {
    output $RIGHT4K enable position 0,0
}
profile desktop-both {
    output $LEFT4K enable position 0,0
    output $RIGHT4K enable position 3840,0
}
