                    }
                }
            ],
            "checkPolicy": {
                "schedule": {
                    "cron": "0 4 1 * *",
                    "clock": "CLOCK_LOCAL"
                },
                "readDataSubsetPercent": 20
            },
            "commandPrefix": {},
