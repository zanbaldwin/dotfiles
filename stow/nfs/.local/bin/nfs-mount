#!/usr/bin/env bash

# Mount the home-network NFS shares on demand.
#
# Flow:
#   - If the NFS server is reachable, just mount.
#   - If not, bring up healthy Tailscale container, and then mount.
#
# All privileged work runs in a single pkexec call to nfs-pkexec, so there
# is exactly one polkit prompt and it works from a desktop launcher (no TTY,
# where sudo could not prompt).
set -euo pipefail

SELF="$(readlink -f -- "$0")"
THIS_DIR="$(dirname -- "${SELF}")"
HELPER="${THIS_DIR}/nfs-pkexec"

# Shared config (SERVER, SERVER_PORT, CONTAINER, ...). Read from the user's home;
# the helper reads the same file under root via the invoking user's home.
CONFIG="${HOME}/.config/nfs/config.sh"
# shellcheck source=../../.config/nfs/config.sh disable=SC1091
if [[ -r "${CONFIG}" ]]; then
    source "${CONFIG}"
else
    echo "nfs-mount: config not found at ${CONFIG}" >&2
    exit 1
fi

# Fail before the polkit prompt if the config is missing what we need.
for var in SERVER SERVER_PORT CONTAINER; do
    if [[ -z "${!var:-}" ]]; then
        echo "nfs-mount: config error: ${var} is not set in ${CONFIG}" >&2
        exit 1
    fi
done

notify() {
    # $1 = urgency (normal|critical), $2 = message
    command -v notify-send >'/dev/null' 2>&1 && notify-send --urgency="$1" 'NFS Mounts' "$2" || true
}

# A 2s TCP probe to the NFS port. Off-network the .lan name only resolves once
# Tailscale is up, so this fails fast and routes us through the Tailscale path.
# @see https://mareksuppa.com/til/bash-dev-tcp-http-without-curl/
if timeout 2 bash -c "exec 3<>/dev/tcp/${SERVER}/${SERVER_PORT}" 2>'/dev/null'; then
    MODE='mount'
else
    MODE='connect'
fi

rc=0
pkexec "${HELPER}" "${MODE}" || rc=$?

case "${rc}" in
    0)
        notify 'normal' 'NFS shares mounted.'
        ;;
    3)
        msg="Tailscale container '${CONTAINER}' does not exist; cannot reach the NFS server."
        echo "nfs-mount: ${msg}" >&2; notify 'critical' "${msg}"
        ;;
    4)
        msg="Tailscale (${CONTAINER}) did not become healthy; shares not mounted."
        echo "nfs-mount: ${msg}" >&2; notify 'critical' "${msg}"
        ;;
    5)
        msg='Failed to mount one or more NFS shares.'
        echo "nfs-mount: ${msg}" >&2; notify 'critical' "${msg}"
        ;;
    126|127)
        msg='Authentication is required to mount the NFS shares.'
        echo "nfs-mount: ${msg}" >&2; notify 'critical' "${msg}"
        ;;
    *)
        msg="nfs-mount failed (exit ${rc})."
        echo "nfs-mount: ${msg}" >&2; notify 'critical' "${msg}"
        ;;
esac

exit "${rc}"
